# Provider/API credentials
OPENAI_API_KEY=sk-proj-...
ANTHROPIC_API_KEY=sk-ant-...
GEMINI_API_KEY=AIza...
MOONSHOT_API_KEY=sk-...
MINIMAX_API_KEY=sk-api-...
