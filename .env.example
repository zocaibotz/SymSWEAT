SWEAT_CODER_TERTIARY=moonshot/kimi-k2.5
SWEAT_LLM_PRIMARY=minimax/MiniMax-M2.7
SWEAT_LLM_SECONDARY=openai-codex/gpt-5.3-codex
SWEAT_LLM_TERTIARY=moonshot/kimi-k2.5

# Model compatibility overrides
